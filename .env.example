# =============================================================================
# FastAPI Backend Environment Variables
# =============================================================================
# This .env file is for the FastAPI backend only.
# The web-react-router app has its own .env in apps/web-react-router/.env
# =============================================================================

# Server port (default: 8000, Railway sets this automatically)
# For worktrees, this is set automatically by worktree-create.sh
# PORT=8000

# Get your OpenAI API Key here: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=****

# Anthropic API key — named SERNIA_ANTHROPIC_API_KEY (not ANTHROPIC_API_KEY)
# to avoid colliding with the ANTHROPIC_API_KEY that Claude Cloud injects for
# the Claude Code session in remote dev environments. api/index.py bridges
# this to ANTHROPIC_API_KEY at startup so the Anthropic SDK auto-discovers it.
SERNIA_ANTHROPIC_API_KEY=****

CRON_SECRET=****
OPEN_PHONE_WEBHOOK_WEBHOOK_SECRET=****
OPEN_PHONE_API_KEY=****

# Sernia MCP server — Clerk OAuth (see api/src/sernia_mcp/README.md for setup).
# All four must be set or the /api/mcp endpoint won't mount. Public base URL
# must exactly match the authorized redirect URI in the Clerk OAuth app's
# dashboard (the redirect is ${SERNIA_MCP_BASE_URL}/auth/callback).
FASTMCP_SERVER_AUTH_CLERK_DOMAIN=your-instance.clerk.accounts.dev
FASTMCP_SERVER_AUTH_CLERK_CLIENT_ID=****
FASTMCP_SERVER_AUTH_CLERK_CLIENT_SECRET=****
SERNIA_MCP_BASE_URL=https://dev.eesposito.com/api/mcp

# POSTGRES

## Postgres Local (for local docker compose) 
## Would need Neon variables on Railway instead of local postgres.
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio"
DATABASE_URL_UNPOOLED="postgresql://portfolio:portfolio@localhost:5432/portfolio"
DATABASE_REQUIRE_SSL=false # needed for local dev when using local postgres only. otherwise app assumes true. 

## Postgres Remote (Neon) variables. The only Neon variables you actually need
## DATABASE_URL="postgres://user:password@ep-something.pooler.region.aws.neon.tech/neondb" # for sync engine
## DATABASE_URL_UNPOOLED="postgres://user:password@ep-something.region.aws.neon.tech/neondb" # for FastAPI


# simple admin password
ADMIN_PASSWORD_SALT=*********
ADMIN_PASSWORD_HASH=*********

# Clerk (env specifc)
CLERK_SECRET_KEY=**
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY==*********
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY==*********

# Google 
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS=*********

# Clickup
CLICKUP_API_KEY==*********

# *Think* this is for db session management
SESSION_SECRET_KEY==*********


# GitHub PAT for AI agent workspace git sync (optional - local-only if not set)
# Workspace lives at api/src/sernia_ai/workspace/ locally, volume-mounted on Railway
# GITHUB_EMILIO_PERSONAL_WRITE_PAT=ghp_...

# Web Push (VAPID) — generate keys with: py_vapid --gen
# VAPID_PRIVATE_KEY=<PEM private key, -----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY----->
# VAPID_PUBLIC_KEY=<URL-safe base64 public key for applicationServerKey>
# VAPID_CLAIM_EMAIL=mailto:admin@serniacapital.com

# env specific
CUSTOM_RAILWAY_BACKEND_URL=https://<host>:<port>