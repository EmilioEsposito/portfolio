# =============================================================================
# Sernia MCP server — environment variables
# =============================================================================
# This service is deployable as its own Railway service (no shared venv with
# the FastAPI monorepo). Copy this file to .env locally; in production, set
# these in Railway's environment.
# =============================================================================

# ---- Public service URL (the host root that Claude/ChatGPT connect to) -----
# Production:  https://mcp.sernia.ai
# Local dev:   http://localhost:8080  (or your ngrok URL during connector tests)
SERNIA_MCP_BASE_URL=http://localhost:8080

# ---- Clerk OAuth (required for remote AI clients) --------------------------
# All four together gate whether OAuth is enabled. Leave them blank to run
# in unauthenticated mode (local dev only — never expose unauthed publicly).
# Set up an OAuth Application in your Clerk dashboard. See README.md.
FASTMCP_SERVER_AUTH_CLERK_DOMAIN=
FASTMCP_SERVER_AUTH_CLERK_CLIENT_ID=
FASTMCP_SERVER_AUTH_CLERK_CLIENT_SECRET=

# ---- Internal bearer token (secondary auth, server-to-server) -------------
# Optional second auth path alongside Clerk OAuth. Requests presenting
# `Authorization: Bearer <token>` matching this value get a synthesized
# AccessToken with `service:sernia-ai` claims that pass the email-domain
# allowlist. Used by the api/ Sernia AI agent calling this MCP server
# without the OAuth dance. Both services must share the same value.
#
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
# Minimum length is 32 chars; the server refuses to boot below that.
# SERNIA_MCP_INTERNAL_BEARER_TOKEN=

# ---- Local-dev auth bypass --------------------------------------------------
# Set to true to force unauthenticated mode even when Clerk/bearer are
# configured. Intended for the MCP Inspector / curl / local exploration only.
# The server raises at boot if this is set on Railway (RAILWAY_ENVIRONMENT_NAME
# present) so it can't escape to production.
# SERNIA_MCP_DISABLE_AUTH=true

# ---- Acting user identity (POC: single user) -------------------------------
# Email of the Google Workspace user whose mailbox is impersonated for Gmail
# tools. Must have domain-wide delegation enabled.
SERNIA_MCP_DEFAULT_USER=emilio@serniacapital.com

# ---- Workspace storage -----------------------------------------------------
# Where the MCP stores MEMORY.md and skills/<name>/SKILL.md. The directory is
# git-backed (clone/pull at startup, commit/push after every edit_resource or
# write_resource) to EmilioEsposito/sernia-knowledge — see GITHUB_EMILIO_PERSONAL_WRITE_PAT
# below. The same repo backs the api/src/sernia_ai agent, so edits flow between
# both services through git.
# Default is `./workspace/` next to this server's CWD. On Railway, point this
# at a mounted volume (e.g. /data/workspace) for persistence across redeploys.
SERNIA_MCP_WORKSPACE_PATH=./workspace

# ---- Upstream API credentials ----------------------------------------------
QUO_API_KEY=
CLICKUP_API_KEY=

# Base64-encoded Google service-account JSON (must have domain-wide delegation
# in Workspace admin). Same value the FastAPI monorepo uses.
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS=

# GitHub PAT for syncing the knowledge workspace with the EmilioEsposito/sernia-knowledge
# repo. Same env var the api/ Sernia AI agent uses — both services share the
# repo so edits flow between them. Leave blank for local-only mode (no git sync).
GITHUB_EMILIO_PERSONAL_WRITE_PAT=

# ---- Quo (OpenPhone) routing -----------------------------------------------
# These are stable IDs from the OpenPhone account; override only if you point
# the service at a different OpenPhone workspace.
QUO_SERNIA_AI_PHONE_ID=PNWvNqsFFy
QUO_SHARED_EXTERNAL_PHONE_ID=PNpTZEJ7la
QUO_INTERNAL_COMPANY=Sernia Capital LLC

# ---- ClickUp ---------------------------------------------------------------
CLICKUP_TEAM_ID=90131316997

# ---- Sernia constants ------------------------------------------------------
INTERNAL_EMAIL_DOMAIN=serniacapital.com

# ---- Authorization allowlist -----------------------------------------------
# Authenticated users (via Clerk) whose email domain is NOT on this list are
# rejected at the FastMCP middleware layer with AuthorizationError. Comma-
# separated. Defaults to INTERNAL_EMAIL_DOMAIN — uncomment to extend.
# SERNIA_MCP_ALLOWED_EMAIL_DOMAINS=serniacapital.com,partner.example

# ---- Logfire (optional) ----------------------------------------------------
# LOGFIRE_TOKEN=
